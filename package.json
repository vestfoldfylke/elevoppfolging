{
  "name": "elevoppfolging",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run check && vite dev",
    "build": "vite build --mode build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "tsc --noEmit && biome check && npm run check && npm run build",
    "lint": "npx @biomejs/biome check",
    "lint:fix": "npx @biomejs/biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@digdir/designsystemet-types": "^1.13.1",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.6.0",
    "svelte": "^5.55.3",
    "svelte-check": "^4.4.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.8"
  },
  "dependencies": {
    "@digdir/designsystemet-css": "^1.13.1",
    "@digdir/designsystemet-web": "^1.13.1",
    "@navikt/fnrvalidator": "^2.2.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@vestfoldfylke/loglady": "^1.5.3",
    "mongodb": "^7.1.1"
  }
}
